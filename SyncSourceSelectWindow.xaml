<Window x:Class="StS2ModManager.SyncSourceSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择同步目录"
        Width="560"
        Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinWidth="460"
        MinHeight="320"
        Background="#F4F8FC">
    <Border Margin="12" CornerRadius="10" Background="White" BorderBrush="#D7E2EE" BorderThickness="1" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderText"
                       Text="请选择要同步的目录"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="#123047"/>

            <TextBlock x:Name="HintText"
                       Grid.Row="1"
                       Margin="0,8,0,0"
                       Text="仅会更新你勾选目录下可同步的 Mod。"
                       Foreground="#4B6073"/>

            <Border Grid.Row="2"
                    Margin="0,10,0,0"
                    BorderBrush="#DCE6F1"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#F9FBFD"
                    Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SourceOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,4,0,4" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#1E3247"/>
                                        <TextBlock Text="{Binding SourcePath}" FontSize="11" Foreground="#60798E"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <WrapPanel Grid.Row="3" Margin="0,12,0,0" HorizontalAlignment="Right">
                <Button x:Name="SelectAllButton" Content="全选" Padding="12,5" Click="OnSelectAllClick"/>
                <Button x:Name="UnselectAllButton" Content="全不选" Padding="12,5" Margin="8,0,0,0" Click="OnUnselectAllClick"/>
                <Button x:Name="ConfirmButton" Content="确定" Padding="14,5" Margin="12,0,0,0" IsDefault="True" Click="OnConfirmClick"/>
                <Button x:Name="CancelButton" Content="取消" Padding="14,5" Margin="8,0,0,0" IsCancel="True"/>
            </WrapPanel>
        </Grid>
    </Border>
</Window>
