<Window x:Class="StS2ModManager.DonateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="支持作者"
        Width="560" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F8FC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="如果这个工具对你有帮助，欢迎请作者喝杯咖啡 ☕"
                   FontSize="13"
                   Foreground="#4B6073"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"/>
        <Border Grid.Row="1"
                BorderBrush="#D9E3EF"
                BorderThickness="1"
                CornerRadius="8"
                Background="White">
            <Image Source="pack://application:,,,/捐赠支持作者开发.jpeg"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>
        <Button Grid.Row="2"
                Content="关闭"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                Padding="32,7"
                Click="OnClose"/>
    </Grid>
</Window>
