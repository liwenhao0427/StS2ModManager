<Window x:Class="StS2ModManager.SyncProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="同步进度"
        Width="460"
        Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#F4F8FC">
    <Border Margin="14" CornerRadius="10" Background="White" BorderBrush="#D7E2EE" BorderThickness="1" Padding="14">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="正在同步 GitHub Mod"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="#123047"/>
            <TextBlock x:Name="StatusText"
                       Margin="0,10,0,0"
                       Text="准备中..."
                       Foreground="#3B5268"
                       TextWrapping="Wrap"/>
            <ProgressBar x:Name="SyncProgressBar"
                         Margin="0,14,0,0"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         IsIndeterminate="True"/>
            <TextBlock x:Name="CounterText"
                       Margin="0,8,0,0"
                       Text="0/0"
                       HorizontalAlignment="Right"
                       Foreground="#1D5E8A"
                       FontWeight="SemiBold"/>
        </StackPanel>
    </Border>
</Window>
