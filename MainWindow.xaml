<Window x:Class="StS2ModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:StS2ModManager.Helpers"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Width="1080"
        Height="740"
        MinWidth="940"
        MinHeight="640"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
        FontFamily="Bahnschrift"
        Background="#ECF1F7"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <helpers:MiddleEllipsisConverter x:Key="MiddleEllipsisConverter"/>
        <CollectionViewSource x:Key="GroupedToolMods" Source="{Binding ToolMods}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="SourceName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <SolidColorBrush x:Key="CardBrush"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardHeaderBg"     Color="#F7FBFF"/>
        <SolidColorBrush x:Key="LineBrush"        Color="#D9E3EF"/>
        <SolidColorBrush x:Key="TitleBrush"       Color="#123047"/>
        <SolidColorBrush x:Key="PrimaryBrush"     Color="#1177CC"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#0D67AF"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#0F766E"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#0B615A"/>
        <SolidColorBrush x:Key="TextFg"           Color="#304256"/>
        <SolidColorBrush x:Key="SubtextFg"        Color="#587086"/>
        <SolidColorBrush x:Key="MutedFg"          Color="#5D7388"/>
        <SolidColorBrush x:Key="HintFg"           Color="#60798E"/>
        <SolidColorBrush x:Key="VersionFg"        Color="#7A9AB5"/>
        <SolidColorBrush x:Key="StatusOkFg"       Color="#15803D"/>
        <SolidColorBrush x:Key="SyncProgressFg"   Color="#1D5E8A"/>
        <SolidColorBrush x:Key="BtnBg"            Color="#F4F7FB"/>
        <SolidColorBrush x:Key="BtnFg"            Color="#294055"/>
        <SolidColorBrush x:Key="BtnBorder"        Color="#C7D6E7"/>
        <SolidColorBrush x:Key="BtnHover"         Color="#E7EFF8"/>
        <SolidColorBrush x:Key="BtnPress"         Color="#D7E5F4"/>
        <SolidColorBrush x:Key="InputBg"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputFg"          Color="#304256"/>
        <SolidColorBrush x:Key="InputBorder"      Color="#C7D6E7"/>
        <SolidColorBrush x:Key="ListBg"           Color="#F9FBFD"/>
        <SolidColorBrush x:Key="ListBorder"       Color="#D7E2EE"/>
        <SolidColorBrush x:Key="FilterCardBg"     Color="#F7FBFF"/>
        <SolidColorBrush x:Key="FilterCardBorder" Color="#D7E5F2"/>
        <SolidColorBrush x:Key="ModPathBg"        Color="#FFF2E5"/>
        <SolidColorBrush x:Key="ModPathBorder"    Color="#E1B48A"/>
        <SolidColorBrush x:Key="ModPathFg"        Color="#8A4F1D"/>
        <SolidColorBrush x:Key="ModTagBg"         Color="#E8F4FF"/>
        <SolidColorBrush x:Key="ModTagBorder"     Color="#9AC5E8"/>
        <SolidColorBrush x:Key="ModTagFg"         Color="#1D5E8A"/>
        <SolidColorBrush x:Key="TagAreaBg"        Color="#F6FAFF"/>
        <SolidColorBrush x:Key="TagAreaBorder"    Color="#D7E5F2"/>
        <SolidColorBrush x:Key="TagChipBg"        Color="#E8F3FF"/>
        <SolidColorBrush x:Key="TagChipBorder"    Color="#A8C9EA"/>
        <SolidColorBrush x:Key="TagChipFg"        Color="#1D5E8A"/>
        <SolidColorBrush x:Key="TagRemoveBg"      Color="#E7EEF6"/>
        <SolidColorBrush x:Key="TagRemoveBorder"  Color="#BFD2E6"/>
        <SolidColorBrush x:Key="TagRemoveFg"      Color="#36536D"/>
        <SolidColorBrush x:Key="DonateBg"     Color="#FFF8EC"/>
        <SolidColorBrush x:Key="DonateFg"     Color="#8A6A2A"/>
        <SolidColorBrush x:Key="DonateBorder" Color="#E8D5A0"/>
        <SolidColorBrush x:Key="StatusBarFg"  Color="#4B6073"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource BtnFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BtnPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0A5F9F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0A588F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0C5B55"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#094D47"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#C65A0A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#9F4908"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AD4F09"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#914307"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputFg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style x:Key="MetaTextBoxAutoSaveStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <EventSetter Event="LostFocus" Handler="OnMetaEditorLostFocus"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#304256"/>
            <Setter Property="BorderBrush" Value="#C7D6E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="MetaComboBoxAutoSaveStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <EventSetter Event="LostFocus" Handler="OnMetaEditorLostFocus"/>
        </Style>

        <Style x:Key="TagRemoveButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource TagRemoveBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TagRemoveBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource TagRemoveFg}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ListBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ListBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10" Background="{DynamicResource CardHeaderBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Loc[App.Title]}" FontSize="27" FontWeight="Bold" Foreground="{DynamicResource TitleBrush}"/>
                        <TextBlock Text="{Binding AppVersion}" FontSize="14" FontWeight="Normal" Foreground="{DynamicResource VersionFg}" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Loc[App.Subtitle]}" Margin="0,4,0,0" Foreground="{DynamicResource SubtextFg}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,4,0">
                    <TextBlock Text="{Binding Loc[Language.Label]}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="132"
                              ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguageOption}"
                              DisplayMemberPath="Label"/>
                </WrapPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,2,0">
                    <Button Content="{Binding Loc[Common.Donate]}"
                            Command="{Binding ShowDonateCommand}"
                            Padding="8,4"
                            Height="28"
                            Margin="0,0,4,0"
                            FontSize="11"
                            Foreground="{DynamicResource DonateFg}"
                            Background="{DynamicResource DonateBg}"
                            BorderBrush="{DynamicResource DonateBorder}"
                            ToolTip="支持作者开发"/>
                    <Button Content="{Binding DarkModeIcon}"
                            Command="{Binding ToggleDarkModeCommand}"
                            Padding="8,4"
                            Height="28"
                            Margin="0,0,6,0"
                            FontSize="13"
                            ToolTip="{Binding Loc[Common.ToggleDark]}"/>
                    <TextBlock Text="🎮" FontSize="28" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Loc[Path.Label]}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="440" ItemsSource="{Binding DetectedPaths}" SelectedItem="{Binding SelectedPath}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource MiddleEllipsisConverter}, ConverterParameter=48}"
                                               ToolTip="{Binding}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </WrapPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button Content="{Binding Loc[Common.Refresh]}" Command="{Binding RefreshPathsCommand}" Padding="10,5"/>
                        <Button Content="{Binding Loc[Common.Browse]}" Command="{Binding BrowseGamePathCommand}" Margin="6,0,0,0" Padding="10,5"/>
                        <Button Content="{Binding Loc[Launch.Steam]}" Command="{Binding LaunchGameViaSteamCommand}" Style="{StaticResource AccentButtonStyle}" Padding="12,6"/>
                        <Button Content="{Binding Loc[Launch.SteamNoMods]}" Command="{Binding LaunchGameViaSteamNoModsCommand}" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="6,0,0,0"/>
                        <Button Content="{Binding Loc[Launch.Direct]}" Command="{Binding LaunchGameCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" Margin="10,0,0,0"/>
                        <Button Content="{Binding Loc[Launch.DirectNoMods]}" Command="{Binding LaunchGameNoModsCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" Margin="6,0,0,0"/>
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding GamePathStatus}" Foreground="{DynamicResource StatusOkFg}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="{Binding Loc[Path.OpenGameDir]}" Command="{Binding OpenGameDirectoryCommand}" Margin="14,0,0,0" Padding="9,4"/>
                        <Button Content="{Binding Loc[Path.OpenGameMods]}" Command="{Binding OpenGameModsDirectoryCommand}" Padding="9,4"/>
                        <Button Content="{Binding Loc[Path.OpenPendingMods]}" Command="{Binding OpenPendingModsDirectoryCommand}" Padding="9,4"/>
                        <Button Content="{Binding Loc[Path.OpenToolMods]}" Command="{Binding OpenToolModsDirectoryCommand}" Padding="9,4"/>
                    </WrapPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button Content="{Binding Loc[Save.QuickOpenSaves]}" Command="{Binding OpenSavesDirectoryCommand}" Padding="10,5"/>
                        <Button Content="{Binding Loc[Save.EnableFullConsole]}" Command="{Binding EnableFullConsoleCommand}" Margin="6,0,0,0" Padding="10,5"/>
                        <Button Content="{Binding Loc[Save.QuickCopyNormalToMod]}" Command="{Binding QuickCopyNormalToModCommand}" Margin="6,0,0,0" Padding="10,5" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="{Binding Loc[Save.QuickCopyModToNormal]}" Command="{Binding QuickCopyModToNormalCommand}" Margin="6,0,0,0" Padding="10,5" Style="{StaticResource AccentButtonStyle}"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
            <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="ToolModsPanel"
                            Grid.Column="0"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="0,0,6,0"
                            Height="900">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Loc[ModList.Title]}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TitleBrush}"/>
                                <Button Content="{Binding Loc[Common.Refresh]}" Command="{Binding RefreshToolModsCommand}" Margin="10,0,0,0" Padding="10,3"/>
                                <Button Content="{Binding Loc[Mods.SyncGithub]}"
                                        Command="{Binding SyncGithubModsCommand}"
                                        Margin="8,0,0,0"
                                        Padding="10,3"
                                        Style="{StaticResource WarningButtonStyle}"/>
                                <Button Content="{Binding Loc[Mods.RestoreAllGithub]}"
                                        Command="{Binding RestoreAllGithubUpdatesCommand}"
                                        Margin="8,0,0,0"
                                        Padding="10,3"/>
                                <Button Content="{Binding Loc[Mods.OpenGithubLogs]}"
                                        Command="{Binding OpenGithubSyncLogsCommand}"
                                        Margin="8,0,0,0"
                                        Padding="10,3"/>
                                <TextBlock Text="{Binding GithubSyncProgressText}" Margin="8,2,0,0" Foreground="{DynamicResource SyncProgressFg}" FontWeight="SemiBold"/>
                            </WrapPanel>

                            <WrapPanel Grid.Row="1" Margin="0,10,0,2" VerticalAlignment="Top">
                                <Border Margin="0,0,12,8" Padding="10,8,10,6" Background="{DynamicResource FilterCardBg}" BorderBrush="{DynamicResource FilterCardBorder}" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[Common.Search]}" Margin="0,0,0,4" FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                                        <TextBox Width="180" Text="{Binding ModSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,12,8" Padding="10,8,10,6" Background="{DynamicResource FilterCardBg}" BorderBrush="{DynamicResource FilterCardBorder}" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[Common.Tag]}" Margin="0,0,0,4" FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                                        <ComboBox Width="130" ItemsSource="{Binding TagFilters}" SelectedItem="{Binding SelectedTagFilter}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,0,8" Padding="10,8,10,6" Background="{DynamicResource FilterCardBg}" BorderBrush="{DynamicResource FilterCardBorder}" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[Common.Author]}" Margin="0,0,0,4" FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                                        <ComboBox Width="130" ItemsSource="{Binding AuthorFilters}" SelectedItem="{Binding SelectedAuthorFilter}"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <Border Grid.Row="2"
                                    Margin="0,8,0,0"
                                    BorderBrush="{DynamicResource ListBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Background="{DynamicResource ListBg}">
                                <ListBox BorderThickness="0"
                                         ItemsSource="{Binding FilteredToolModsView}"
                                         SelectedItem="{Binding SelectedToolMod}"
                                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          Grid.RowSpan="3"
                                                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0,0,8,0"
                                                          Command="{Binding DataContext.ToggleToolModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="{DynamicResource TitleBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="  " />
                                                    <TextBlock Text="{Binding AuthorDisplay}" FontSize="11" Foreground="{DynamicResource MutedFg}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding LocationDisplay}" FontSize="11" Foreground="{DynamicResource MutedFg}" TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1" Grid.Row="2" Margin="0,3,0,0" Padding="6,2" Background="{DynamicResource ModPathBg}" BorderBrush="{DynamicResource ModPathBorder}" BorderThickness="1" CornerRadius="4">
                                                    <TextBlock Text="{Binding SourcePath}" FontSize="10" Foreground="{DynamicResource ModPathFg}" TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" Grid.RowSpan="3" Margin="10,0,0,0" HorizontalAlignment="Right">
                                                    <Border Padding="6,1" Background="{DynamicResource ModTagBg}" BorderBrush="{DynamicResource ModTagBorder}" BorderThickness="1" CornerRadius="4" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Tag}" FontSize="10" Foreground="{DynamicResource ModTagFg}" TextAlignment="Right"/>
                                                    </Border>
                                                    <Button Content="{Binding DataContext.Loc[Common.Open], RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Command="{Binding DataContext.OpenModFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="8,2"
                                                            Width="62"
                                                            Margin="0,6,0,0"
                                                            HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                                <Button Content="{Binding Loc[Source.Add]}" Command="{Binding AddModSourceCommand}"/>
                                <Button Content="{Binding Loc[Source.Remove]}" Command="{Binding RemoveModSourceCommand}"/>
                                <Button Content="{Binding Loc[Source.Open]}" Command="{Binding OpenSelectedModSourceCommand}"/>
                                <Button Content="{Binding Loc[Mods.EnableAll]}" Command="{Binding SelectAllModsCommand}"/>
                                <Button Content="{Binding Loc[Mods.DisableAll]}" Command="{Binding DeselectAllModsCommand}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorderStyle}"
                            Margin="6,0,0,0"
                            Height="900">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding Loc[ModDetail.Title]}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TitleBrush}"/>

                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                 <Grid.RowDefinitions>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                 </Grid.RowDefinitions>
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="74"/>
                                     <ColumnDefinition Width="*"/>
                                 </Grid.ColumnDefinitions>

                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Loc[Field.Name]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                 <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <TextBox Grid.Column="0"
                                              Style="{StaticResource MetaTextBoxAutoSaveStyle}"
                                              Text="{Binding ModNameInput, UpdateSourceTrigger=LostFocus}"/>
                                     <Button Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Padding="10,4"
                                             Content="{Binding Loc[Mods.SyncGithubSingle]}"
                                             Command="{Binding SyncSelectedGithubModCommand}"
                                             Style="{StaticResource WarningButtonStyle}"/>
                                 </Grid>

                                 <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Loc[Field.Tag]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Top"/>
                                 <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
                                     <Border Background="{DynamicResource TagAreaBg}" BorderBrush="{DynamicResource TagAreaBorder}" BorderThickness="1" CornerRadius="8" Padding="8,8,8,6">
                                         <ItemsControl ItemsSource="{Binding ModTags}">
                                             <ItemsControl.ItemsPanel>
                                                 <ItemsPanelTemplate>
                                                     <WrapPanel/>
                                                 </ItemsPanelTemplate>
                                             </ItemsControl.ItemsPanel>
                                             <ItemsControl.ItemTemplate>
                                                 <DataTemplate>
                                                     <Border Margin="0,0,6,6" Padding="8,3" Background="{DynamicResource TagChipBg}" BorderBrush="{DynamicResource TagChipBorder}" BorderThickness="1" CornerRadius="10">
                                                         <StackPanel Orientation="Horizontal">
                                                             <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource TagChipFg}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                             <Button Content="✕"
                                                                     Style="{StaticResource TagRemoveButtonStyle}"
                                                                     VerticalAlignment="Center"
                                                                     Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     CommandParameter="{Binding}"/>
                                                         </StackPanel>
                                                     </Border>
                                                 </DataTemplate>
                                             </ItemsControl.ItemTemplate>
                                         </ItemsControl>
                                     </Border>
                                     <Grid Margin="0,6,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="220"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <ComboBox Grid.Column="0"
                                                   Height="32"
                                                   ItemsSource="{Binding AvailableTags}"
                                                   SelectedItem="{Binding SelectedTagSuggestion, Mode=TwoWay}"
                                                   IsEditable="True"
                                                   IsTextSearchEnabled="True"
                                                   StaysOpenOnEdit="True"
                                                   Text="{Binding NewTagInput, UpdateSourceTrigger=PropertyChanged}"
                                                   KeyDown="OnTagInputKeyDown"/>
                                         <Button Grid.Column="1"
                                                 Margin="8,0,0,0"
                                                 Padding="10,4"
                                                 Content="+"
                                                 Command="{Binding AddNewTagCommand}"/>
                                     </Grid>
                                     <TextBlock Text="{Binding Loc[Field.TagHint]}" Margin="0,4,0,0" FontSize="10" Foreground="{DynamicResource HintFg}"/>
                                 </StackPanel>

                                 <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Loc[Field.Description]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Top"/>
                                 <TextBox Grid.Row="2" Grid.Column="1"
                                          Margin="0,0,0,6"
                                          Style="{StaticResource MetaTextBoxAutoSaveStyle}"
                                          Text="{Binding ModDescriptionInput, UpdateSourceTrigger=LostFocus}"
                                          AcceptsReturn="True"
                                          TextWrapping="Wrap"
                                          VerticalScrollBarVisibility="Auto"
                                          Height="72"/>

                                 <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Loc[Field.Author]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                 <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModAuthorInput, UpdateSourceTrigger=LostFocus}"/>

                                  <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Loc[Field.DownloadUrl]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                  <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                                      <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="*"/>
                                          <ColumnDefinition Width="Auto"/>
                                      </Grid.ColumnDefinitions>
                                      <TextBox Grid.Column="0" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModDownloadUrlInput, UpdateSourceTrigger=LostFocus}"/>
                                      <Button Grid.Column="1"
                                              Margin="8,0,0,0"
                                              Padding="10,4"
                                              Content="{Binding Loc[Common.Go]}"
                                              Command="{Binding OpenUrlCommand}"
                                              CommandParameter="{Binding ModDownloadUrlInput}"/>
                                  </Grid>

                                 <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding Loc[Field.Remark]}" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Top"/>
                                 <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModRemarkInput, UpdateSourceTrigger=LostFocus}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="72"/>
                              </Grid>

                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="74"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Loc[Field.DetailUrl]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                 <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <TextBox Grid.Column="0" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModDetailUrlInput, UpdateSourceTrigger=LostFocus}"/>
                                     <Button Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Padding="10,4"
                                             Content="{Binding Loc[Common.Go]}"
                                             Command="{Binding OpenUrlCommand}"
                                             CommandParameter="{Binding ModDetailUrlInput}"/>
                                 </Grid>

                                 <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Loc[Field.AuthorUrl]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                 <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <TextBox Grid.Column="0" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModAuthorUrlInput, UpdateSourceTrigger=LostFocus}"/>
                                     <Button Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Padding="10,4"
                                             Content="{Binding Loc[Common.Go]}"
                                             Command="{Binding OpenUrlCommand}"
                                             CommandParameter="{Binding ModAuthorUrlInput}"/>
                                 </Grid>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Loc[Field.Version]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModVersionInput, UpdateSourceTrigger=LostFocus}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Loc[Field.ModId]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModIdInput, UpdateSourceTrigger=LostFocus}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Loc[Field.Dependencies]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Top"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                                    <TextBox Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModDependenciesInput, UpdateSourceTrigger=LostFocus}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="48"/>
                                    <TextBlock Text="{Binding Loc[Field.DependenciesHint]}" Margin="0,4,0,0" FontSize="10" Foreground="{DynamicResource HintFg}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding Loc[Field.AffectsGameplay]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Top"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,6">
                                    <CheckBox Content="{Binding Loc[Field.AffectsGameplay.Checkbox]}"
                                              IsChecked="{Binding ModAffectsGameplayInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Command="{Binding SaveModMetaOnBlurCommand}"/>
                                    <TextBlock Text="{Binding Loc[Field.AffectsGameplayHint]}" Margin="0,4,0,0" FontSize="10" Foreground="{DynamicResource HintFg}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding Loc[Field.Updated]}" HorizontalAlignment="Right" Margin="0,0,8,6" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedModUpdatedDisplay}" IsReadOnly="True"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="{Binding Loc[Field.Detail]}" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource MetaTextBoxAutoSaveStyle}" Text="{Binding ModDetailInput, UpdateSourceTrigger=LostFocus}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="{Binding Loc[Field.GithubRepo]}" HorizontalAlignment="Right" Margin="0,8,8,0" VerticalAlignment="Top"/>
                                <StackPanel Grid.Row="8" Grid.Column="1" Margin="0,8,0,0">
                                    <TextBox Text="{Binding ModGithubRepoUrlInput}" IsReadOnly="True"/>
                                    <WrapPanel Margin="0,6,0,0">
                                        <CheckBox Content="{Binding Loc[Field.GithubSyncEnabled]}"
                                                  IsChecked="{Binding ModGithubSyncEnabledInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{Binding Loc[Field.GithubAvailable]}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding ModGithubSyncAvailableInput}" IsEnabled="False" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                                <Button Content="{Binding Loc[Common.Save]}" Command="{Binding SaveModMetaCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                                <Button Content="{Binding Loc[Common.Reset]}" Command="{Binding ClearModMetaCommand}"/>
                            </WrapPanel>
                        </Grid>
                        </ScrollViewer>
                    </Border>
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Loc[Save.Title]}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TitleBrush}"/>
                            <Button Content="{Binding Loc[Save.OpenSavesDir]}" Command="{Binding OpenSavesDirectoryCommand}" Margin="14,0,0,0"/>
                            <Button Content="{Binding Loc[Save.OpenBackupDir]}" Command="{Binding OpenBackupDirectoryCommand}"/>
                            <Button Content="{Binding Loc[Save.RefreshSteamId]}" Command="{Binding RefreshSteamIdsCommand}"/>
                            <Button Content="{Binding Loc[Save.RefreshBackups]}" Command="{Binding RefreshSaveBackupsCommand}"/>
                            <Button Content="{Binding Loc[Save.EnableFullConsole]}" Command="{Binding EnableFullConsoleCommand}" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="{Binding Loc[Common.Donate]}"
                                    Command="{Binding ShowDonateCommand}"
                                    Margin="8,0,0,0"
                                    Padding="8,4"
                                    FontSize="11"
                                    Foreground="{DynamicResource DonateFg}"
                                    Background="{DynamicResource DonateBg}"
                                    BorderBrush="{DynamicResource DonateBorder}"
                                    ToolTip="支持作者开发"/>
                        </WrapPanel>

                        <WrapPanel Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Loc[Save.SteamId]}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="190" ItemsSource="{Binding SteamIds}" SelectedItem="{Binding SelectedSteamId}"/>
                            <TextBlock Text="{Binding Loc[Save.CopyDirection]}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                            <ComboBox Width="220" ItemsSource="{Binding SaveDirections}" SelectedItem="{Binding SelectedSaveDirection}" DisplayMemberPath="Label"/>
                            <TextBlock Text="{Binding Loc[Save.Slot]}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                            <ComboBox Width="120" ItemsSource="{Binding SaveSlots}" SelectedItem="{Binding SelectedSaveSlot}" DisplayMemberPath="Label"/>
                            <Button Content="{Binding Loc[Save.Copy]}" Command="{Binding CopySaveCommand}" Margin="14,0,0,0" Style="{StaticResource PrimaryButtonStyle}" FontWeight="Bold"/>
                        </WrapPanel>

                        <WrapPanel Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Loc[Save.QuickRestore]}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="430" ItemsSource="{Binding SaveBackups}" SelectedItem="{Binding SelectedSaveBackup}" DisplayMemberPath="DisplayName"/>
                            <TextBlock Text="{Binding Loc[Save.RestoreTo]}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                            <ComboBox Width="190" ItemsSource="{Binding RestoreTargets}" SelectedItem="{Binding SelectedRestoreTarget}" DisplayMemberPath="Label"/>
                            <Button Content="{Binding Loc[Save.RestoreSelected]}" Command="{Binding RestoreSaveBackupCommand}" Margin="14,0,0,0" Style="{StaticResource AccentButtonStyle}" FontWeight="Bold"/>
                        </WrapPanel>

                        <WrapPanel Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Loc[Save.ManualName]}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Width="250" Text="{Binding ManualBackupName, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="{Binding Loc[Save.ManualBackupNow]}" Command="{Binding CreateManualBackupCommand}" Margin="12,0,0,0" Style="{StaticResource PrimaryButtonStyle}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Loc[Save.ManualHint]}" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource HintFg}"/>
                        </WrapPanel>
                    </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="12,8" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusBarFg}"/>
        </Border>
    </Grid>
</Window>
